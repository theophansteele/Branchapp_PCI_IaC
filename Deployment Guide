  <!-- ─────────────────────────────────────────────
       STEP 2 — AWS Setup
  ───────────────────────────────────────────── -->
  <div class="step" id="step-aws">
    <div class="step-header">
      <div class="step-num-large">2</div>
      <div class="step-title-block">
        <div class="step-phase">AWS</div>
        <div class="step-title">Gather AWS Values &amp; Create OIDC Role</div>
      </div>
    </div>

    <p class="step-desc">You need several AWS identifiers, a pre-existing VPC with CDE subnets, and an OIDC role for GitHub Actions to authenticate without long-lived keys.</p>

    <div class="substep">
      <div class="substep-title">Collect required AWS values</div>
      <div class="code-block">
        <div class="code-label">terminal — run these to find your values<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Your AWS account ID</span>
aws sts get-caller-identity --query Account --output text
<span class="c"># → copy the 12-digit number  e.g. 123456789012</span>

<span class="c"># Your VPC ID (VPC hosting the CDE)</span>
aws ec2 describe-vpcs --query 'Vpcs[?IsDefault==`false`].VpcId' --output table

<span class="c"># Subnet IDs inside that VPC (the CDE subnets)</span>
aws ec2 describe-subnets \
  --filters "Name=vpc-id,Values=<span class="i-aws">YOUR-VPC-ID</span>" \
  --query 'Subnets[].SubnetId' --output text</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Create the GitHub Actions OIDC role</div>
      <p style="font-size:0.8rem;color:var(--text2);margin-bottom:0.6rem;">This lets GitHub Actions authenticate to AWS without storing access keys as secrets.</p>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># 1. Create the OIDC provider (only once per account)</span>
aws iam create-open-id-connect-provider \
  --url https://token.actions.githubusercontent.com \
  --client-id-list sts.amazonaws.com \
  --thumbprint-list 6938fd4d98bab03faadb97b34396831e3780aea1

<span class="c"># 2. Create the trust policy file</span>
cat > /tmp/github-oidc-trust.json &lt;&lt; 'EOF'
{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Principal": {
      "Federated": "arn:aws:iam::<span class="i-aws">YOUR-ACCOUNT-ID</span>:oidc-provider/token.actions.githubusercontent.com"
    },
    "Action": "sts:AssumeRoleWithWebIdentity",
    "Condition": {
      "StringEquals": {
        "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
      },
      "StringLike": {
        "token.actions.githubusercontent.com:sub": "repo:<span class="i-gh">YOUR-ORG</span>/<span class="i-gh">pci-compliance</span>:*"
      }
    }
  }]
}
EOF

<span class="c"># 3. Create the role</span>
aws iam create-role \
  --role-name GitHubActionsPCIRole \
  --assume-role-policy-document file:///tmp/github-oidc-trust.json

<span class="c"># 4. Attach AdministratorAccess (for Terraform to manage resources)</span>
aws iam attach-role-policy \
  --role-name GitHubActionsPCIRole \
  --policy-arn arn:aws:iam::aws:policy/AdministratorAccess

<span class="c"># 5. Get the role ARN — you'll need this for GitHub secrets</span>
aws iam get-role --role-name GitHubActionsPCIRole \
  --query Role.Arn --output text
<span class="c"># → arn:aws:iam::123456789012:role/GitHubActionsPCIRole</span></pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Create Terraform remote state bucket</div>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Create S3 bucket for Terraform state</span>
aws s3api create-bucket \
  --bucket <span class="i-aws">branch-terraform-state</span> \
  --region us-east-1

<span class="c"># Enable versioning on the state bucket</span>
aws s3api put-bucket-versioning \
  --bucket <span class="i-aws">branch-terraform-state</span> \
  --versioning-configuration Status=Enabled

<span class="c"># Block all public access</span>
aws s3api put-public-access-block \
  --bucket <span class="i-aws">branch-terraform-state</span> \
  --public-access-block-configuration \
    BlockPublicAcls=true,IgnorePublicAcls=true,\
    BlockPublicPolicy=true,RestrictPublicBuckets=true

<span class="c"># Create DynamoDB table for state locking</span>
aws dynamodb create-table \
  --table-name <span class="i-aws">branch-terraform-locks</span> \
  --attribute-definitions AttributeName=LockID,AttributeType=S \
  --key-schema AttributeName=LockID,KeyType=HASH \
  --billing-mode PAY_PER_REQUEST \
  --region us-east-1</pre>
      </div>
      <div class="callout callout-info">
        <span class="callout-icon">ℹ️</span>
        <div class="callout-body">
          <strong>Bucket name must be globally unique.</strong>
          If <code>branch-terraform-state</code> is taken, use <code>branch-terraform-state-<span class="i-aws">YOUR-ACCOUNT-ID</span></code>. Update <code>providers.tf</code> to match.
        </div>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Values to record from this step <span class="pill pill-aws">AWS</span></div>
      <table class="input-table">
        <thead><tr><th>Variable</th><th>Where to find it</th><th>Example</th></tr></thead>
        <tbody>
          <tr class="row-aws"><td class="key">aws_account_id</td><td class="desc"><code>aws sts get-caller-identity</code></td><td class="where"><code>123456789012</code></td></tr>
          <tr class="row-aws"><td class="key">vpc_id</td><td class="desc">EC2 → VPC → your CDE VPC</td><td class="where"><code>vpc-0a1b2c3d4e5f</code></td></tr>
          <tr class="row-aws"><td class="key">cde_subnet_ids</td><td class="desc">EC2 → Subnets → filter by VPC</td><td class="where"><code>["subnet-abc","subnet-def"]</code></td></tr>
          <tr class="row-aws"><td class="key">AWS_OIDC_ROLE_ARN</td><td class="desc">Output of create-role command above</td><td class="where"><code>arn:aws:iam::123…:role/GitHubActionsPCIRole</code></td></tr>
          <tr class="row-aws"><td class="key">TF_STATE_BUCKET</td><td class="desc">Bucket you created above</td><td class="where"><code>branch-terraform-state</code></td></tr>
          <tr class="row-aws"><td class="key">TF_LOCK_TABLE</td><td class="desc">DynamoDB table you created</td><td class="where"><code>branch-terraform-locks</code></td></tr>
        </tbody>
      </table>
    </div>
  </div>

