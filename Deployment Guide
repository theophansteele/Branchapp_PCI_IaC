  <div class="step" id="step-tfvars">
    <div class="step-header">
      <div class="step-num-large">6</div>
      <div class="step-title-block">
        <div class="step-phase">Terraform</div>
        <div class="step-title">Create <code>terraform.tfvars</code></div>
      </div>
    </div>

    <p class="step-desc">Create this file in the project root. Every highlighted value must be replaced. This file is git-ignored — never commit it.</p>

    <div class="callout callout-danger">
      <span class="callout-icon">🚫</span>
      <div class="callout-body">
        <strong>This file must never be committed to git.</strong>
        Verify with <code>git status</code> — it should not appear. If it does, <code>git rm --cached terraform.tfvars</code> immediately.
      </div>
    </div>

    <div class="code-block">
      <div class="code-label">terraform.tfvars — create in project root<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="c"># ─── Global ──────────────────────────────────────────</span>
environment = <span class="s">"production"</span>

<span class="c"># ─── AWS ─────────────────────────────────────────────</span>
aws_region     = <span class="s">"<span class="i-aws">us-east-1</span>"</span>                  <span class="c"># Change if different</span>
aws_account_id = <span class="s">"<span class="i-aws">YOUR-12-DIGIT-ACCOUNT-ID</span>"</span>   <span class="c"># e.g. "123456789012"</span>

vpc_id         = <span class="s">"<span class="i-aws">vpc-XXXXXXXXXXXXXXXXX</span>"</span>       <span class="c"># Your CDE VPC</span>
cde_subnet_ids = [
  <span class="s">"<span class="i-aws">subnet-XXXXXXXXXXXXXXXXX</span>"</span>,               <span class="c"># CDE subnet 1 (AZ-a)</span>
  <span class="s">"<span class="i-aws">subnet-YYYYYYYYYYYYYYYYY</span>"</span>                <span class="c"># CDE subnet 2 (AZ-b)</span>
]

<span class="c"># CIDRs that can SSH to CDE instances (your VPN/bastion IPs)</span>
allowed_admin_cidrs = [<span class="s">"<span class="i-aws">YOUR-VPN-CIDR/32</span>"</span>]    <span class="c"># e.g. "10.1.0.5/32"</span>

s3_log_bucket_name       = <span class="s">"<span class="i-aws">branch-pci-audit-logs</span>"</span>    <span class="c"># Must be globally unique</span>
cloudtrail_name          = <span class="s">"branch-pci-cloudtrail"</span>
sns_alert_email          = <span class="s">"<span class="i-req">security@yourcompany.com</span>"</span>  <span class="c"># PCI alert destination</span>
kms_deletion_window_days = 30

<span class="c"># ─── GCP ─────────────────────────────────────────────</span>
gcp_project_id  = <span class="s">"<span class="i-gcp">your-gcp-project-id</span>"</span>           <span class="c"># e.g. "branch-prod-12345"</span>
gcp_region      = <span class="s">"<span class="i-gcp">us-central1</span>"</span>                   <span class="c"># Change if different</span>
gcp_network_name = <span class="s">"<span class="i-gcp">branch-pci-network</span>"</span>           <span class="c"># Your GCP VPC network name</span>

<span class="c"># ─── Cloudflare ──────────────────────────────────────</span>
cloudflare_api_token  = <span class="s">"<span class="i-cf">YOUR-CLOUDFLARE-API-TOKEN</span>"</span>    <span class="c"># From Step 4</span>
cloudflare_zone_id    = <span class="s">"<span class="i-cf">YOUR-CLOUDFLARE-ZONE-ID</span>"</span>      <span class="c"># 32-char hex string</span>
cloudflare_account_id = <span class="s">"<span class="i-cf">YOUR-CLOUDFLARE-ACCOUNT-ID</span>"</span>   <span class="c"># 32-char hex string</span>

<span class="c"># ─── Drata ───────────────────────────────────────────</span>
drata_external_id    = <span class="s">"<span class="i-drata">UUID-FROM-DRATA-CONNECTIONS-WIZARD</span>"</span> <span class="c"># From Step 5</span>
drata_aws_account_id = <span class="s">"269135526815"</span>                 <span class="c"># Drata's published AWS account</span>

<span class="c"># Run terraform apply first, then paste the output here:</span>
<span class="c"># drata_gcp_service_account_id = "leave blank on first apply"</span>
drata_gcp_service_account_id = <span class="s">"<span class="i-drata">PASTE-AFTER-FIRST-APPLY</span>"</span></pre>
    </div>

    <div class="callout callout-tip">
      <span class="callout-icon">💡</span>
      <div class="callout-body">
        <strong>Two-pass apply for <code>drata_gcp_service_account_id</code>.</strong>
        On the first apply, set it to any placeholder string (e.g. <code>"placeholder"</code>). After apply runs, grab the real value with <code>terraform output drata_gcp_service_account_email</code>, update the tfvars, and run <code>terraform apply</code> again to bind the workload identity.
      </div>
    </div>
  </div>

  <!-- ─────────────────────────────────────────────
       STEP 7 — GitHub Secrets
  ───────────────────────────────────────────── -->
  <div class="step" id="step-secrets">
    <div class="step-header">
      <div class="step-num-large">7</div>
      <div class="step-title-block">
        <div class="step-phase">GitHub</div>
        <div class="step-title">Add Repository Secrets</div>
      </div>
    </div>

    <p class="step-desc">Go to <strong>github.com/YOUR-ORG/pci-compliance → Settings → Secrets and variables → Actions → New repository secret</strong> and add every secret in the table below.</p>

    <table class="input-table">
      <thead><tr><th>Secret Name</th><th>Value</th><th>Source</th></tr></thead>
      <tbody>
        <tr class="row-aws"><td class="key">AWS_OIDC_ROLE_ARN</td><td class="desc">ARN of the GitHubActionsPCIRole</td><td class="where">Step 2 → create-role output</td></tr>
        <tr class="row-aws"><td class="key">AWS_ACCOUNT_ID</td><td class="desc">12-digit AWS account ID</td><td class="where"><code>aws sts get-caller-identity</code></td></tr>
        <tr class="row-aws"><td class="key">TF_STATE_BUCKET</td><td class="desc">S3 bucket name for Terraform state</td><td class="where">Step 2 → bucket you created</td></tr>
        <tr class="row-aws"><td class="key">TF_LOCK_TABLE</td><td class="desc">DynamoDB table name</td><td class="where">Step 2 → table you created</td></tr>
        <tr class="row-aws"><td class="key">VPC_ID</td><td class="desc">Your CDE VPC ID</td><td class="where">Step 2 → vpc-XXXXX</td></tr>
        <tr class="row-aws"><td class="key">CDE_SUBNET_IDS</td><td class="desc">JSON array of subnet IDs</td><td class="where"><code>["subnet-abc","subnet-def"]</code></td></tr>
        <tr class="row-cf"><td class="key">CLOUDFLARE_API_TOKEN</td><td class="desc">Scoped Cloudflare API token</td><td class="where">Step 4 → token you created</td></tr>
        <tr class="row-cf"><td class="key">CLOUDFLARE_ZONE_ID</td><td class="desc">32-char zone ID</td><td class="where">Step 4 → API output</td></tr>
        <tr class="row-cf"><td class="key">CLOUDFLARE_ACCOUNT_ID</td><td class="desc">32-char account ID</td><td class="where">Step 4 → API output</td></tr>
        <tr class="row-gcp"><td class="key">GCP_PROJECT_ID</td><td class="desc">GCP project ID string</td><td class="where">Step 3 → gcloud projects list</td></tr>
        <tr class="row-drata"><td class="key">DRATA_EXTERNAL_ID</td><td class="desc">UUID from Drata connections wizard</td><td class="where">Step 5 → Drata UI</td></tr>
        <tr class="row-drata"><td class="key">DRATA_GCP_SA_ID</td><td class="desc">GCP SA unique ID (after first apply)</td><td class="where"><code>terraform output drata_gcp_service_account_email</code></td></tr>
        <tr class="row-req"><td class="key">PCI_ALERT_EMAIL</td><td class="desc">Email for CloudWatch/SNS PCI alerts</td><td class="where">Your security team email</td></tr>
        <tr class="row-opt"><td class="key">SLACK_WEBHOOK_URL</td><td class="desc">Slack incoming webhook URL (optional)</td><td class="where">Slack → Apps → Incoming Webhooks</td></tr>
      </tbody>
    </table>

    <div class="callout callout-tip">
      <span class="callout-icon">💡</span>
      <div class="callout-body">
        <strong>Use GitHub CLI to bulk-add secrets.</strong>
        <code>gh secret set SECRET_NAME --body "value" --repo YOUR-ORG/pci-compliance</code> — faster than clicking through the UI 14 times.
      </div>
    </div>
  </div>

  <!-- ─────────────────────────────────────────────
       STEP 8 — Push & Deploy
  ───────────────────────────────────────────── -->
  <div class="step" id="step-push">
    <div class="step-header">
      <div class="step-num-large">8</div>
      <div class="step-title-block">
        <div class="step-phase">Terraform</div>
        <div class="step-title">Run Terraform &amp; Push to Trigger CI</div>
      </div>
    </div>

    <p class="step-desc">Run Terraform locally first to validate everything, then push to <code>main</code> to trigger the full CI/CD pipeline.</p>

    <div class="substep">
      <div class="substep-title">Local first apply</div>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Initialize providers and remote backend</span>
terraform init

<span class="c"># Validate HCL syntax</span>
terraform validate

<span class="c"># Review the plan — read it carefully before applying</span>
terraform plan -var-file=terraform.tfvars

<span class="c"># Apply — type "yes" when prompted</span>
terraform apply -var-file=terraform.tfvars

<span class="c"># Get the outputs to paste into Drata and second tfvars pass</span>
terraform output</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Second pass for GCP service account binding</div>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Get the service account unique ID from the first apply output</span>
terraform output drata_gcp_service_account_email

<span class="c"># Get the unique ID (needed for Google Workspace domain-wide delegation)</span>
gcloud iam service-accounts describe \
  $(terraform output -raw drata_gcp_service_account_email) \
  --format='value(uniqueId)'
<span class="c"># → copy this number, update drata_gcp_service_account_id in terraform.tfvars</span>

<span class="c"># Apply again to bind workload identity with the correct SA ID</span>
terraform apply -var-file=terraform.tfvars</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Push to trigger GitHub Actions pipeline</div>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Commit any local changes (NOT the tfvars file)</span>
git add -A
git status   <span class="c"># confirm terraform.tfvars is NOT listed</span>
git commit -m "chore: post-deploy config updates"
git push origin main

<span class="c"># Watch the pipeline run</span>
<span class="c"># github.com/YOUR-ORG/pci-compliance/actions</span></pre>
      </div>
    </div>
  </div>

  <!-- ─────────────────────────────────────────────
       STEP 9 — Verify
  ───────────────────────────────────────────── -->
  <div class="step" id="step-verify">
    <div class="step-header">
      <div class="step-num-large">9</div>
      <div class="step-title-block">
        <div class="step-phase">Verification</div>
        <div class="step-title">Verify All Controls Are Active</div>
      </div>
    </div>

    <p class="step-desc">Run these checks after Terraform apply completes to confirm each PCI control is live.</p>

    <div class="substep">
      <div class="substep-title">AWS verification commands</div>
      <div class="code-block">
        <div class="code-label">terminal — AWS<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># CloudTrail — should show IsLogging: true</span>
aws cloudtrail get-trail-status --name branch-pci-cloudtrail \
  --query '{IsLogging:IsLogging,LatestDelivery:LatestDeliveryTime}'

<span class="c"># GuardDuty — should show Status: ENABLED</span>
aws guardduty list-detectors --query 'DetectorIds' --output text | \
  xargs -I{} aws guardduty get-detector --detector-id {} \
  --query '{Status:Status,FindingPublishingFrequency:FindingPublishingFrequency}'

<span class="c"># Security Hub — PCI standard should be READY</span>
aws securityhub get-enabled-standards \
  --query 'StandardsSubscriptions[].{Arn:StandardsArn,Status:StandardsStatus}'

<span class="c"># Config rules — count how many are COMPLIANT</span>
aws configservice describe-compliance-by-config-rule \
  --compliance-types COMPLIANT \
  --query 'length(ComplianceByConfigRules[?starts_with(ConfigRuleName,`branch-pci-`)])'

<span class="c"># KMS key rotation — RotationEnabled should be true</span>
aws kms get-key-rotation-status \
  --key-id alias/branch-pci-cde \
  --query 'KeyRotationEnabled'

<span class="c"># EBS encryption by default — should be true</span>
aws ec2 get-ebs-encryption-by-default --query 'EbsEncryptionByDefault'

<span class="c"># IAM password policy — verify minimums</span>
aws iam get-account-password-policy \
  --query 'PasswordPolicy.{MinLen:MinimumPasswordLength,MaxAge:MaxPasswordAge,Reuse:PasswordReusePrevention}'</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">GCP verification commands</div>
      <div class="code-block">
        <div class="code-label">terminal — GCP<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Audit log sink — verify it exists</span>
gcloud logging sinks list --project=<span class="i-gcp">YOUR-GCP-PROJECT-ID</span>

<span class="c"># KMS key ring — verify created</span>
gcloud kms keyrings list --location=<span class="i-gcp">us-central1</span>

<span class="c"># Firewall rules — verify deny-all exists</span>
gcloud compute firewall-rules list \
  --filter="name:branch-pci" \
  --format="table(name,direction,priority,action)"

<span class="c"># Drata service account — verify created</span>
gcloud iam service-accounts list \
  --filter="displayName:Drata" \
  --format="table(email,displayName)"</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Drata verification checklist</div>
      <ul class="checklist">
        <li><div class="check-box"></div><span class="tag-provider pill pill-aws">AWS</span> Connection shows green in Drata → Infrastructure controls populating</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-gcp">GCP</span> Connection shows green → Infrastructure controls populating</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-cf">CF</span> Cloudflare connection active → WAF controls visible</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-drata">Drata</span> PCI DSS framework selected under Frameworks</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-drata">Drata</span> Controls tab shows auto-collected evidence for Req 1, 3, 7, 10, 11</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-drata">Drata</span> User Access Reviews configured for AWS, GCP, Cloudflare, Google Workspace</li>
        <li><div class="check-box"></div><span class="tag-provider pill pill-drata">Drata</span> SNS alert email subscription confirmed (check inbox for confirmation email)</li>
      </ul>
    </div>
  </div>

  <!-- ─────────────────────────────────────────────
       STEP 10 — GitHub Pages
  ───────────────────────────────────────────── -->
  <div class="step" id="step-pages">
    <div class="step-header">
      <div class="step-num-large">10</div>
      <div class="step-title-block">
        <div class="step-phase">GitHub Pages</div>
        <div class="step-title">Publish the Compliance Dashboard</div>
      </div>
    </div>

    <p class="step-desc">The <code>docs/index.html</code> file in the repo is ready to serve as a GitHub Pages site — your live compliance dashboard.</p>

    <div class="substep">
      <div class="substep-title">Enable GitHub Pages</div>
      <ul class="checklist">
        <li><div class="check-box"></div>Go to <strong>github.com/YOUR-ORG/pci-compliance → Settings → Pages</strong></li>
        <li><div class="check-box"></div>Source: <strong>Deploy from a branch</strong></li>
        <li><div class="check-box"></div>Branch: <strong>main</strong> · Folder: <strong>/docs</strong></li>
        <li><div class="check-box"></div>Click <strong>Save</strong></li>
        <li><div class="check-box"></div>Wait ~2 minutes — dashboard will be live at:</li>
      </ul>
      <div class="code-block">
        <div class="code-label">your dashboard URL</div>
        <pre>https://<span class="i-gh">YOUR-ORG</span>.github.io/<span class="i-gh">pci-compliance</span>/</pre>
      </div>
    </div>

    <div class="substep">
      <div class="substep-title">Optional: custom domain</div>
      <div class="code-block">
        <div class="code-label">terminal<button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="c"># Add a CNAME file if you want a custom domain</span>
echo "<span class="i-opt">compliance.branchapp.com</span>" > docs/CNAME
git add docs/CNAME
git commit -m "feat: custom domain for compliance dashboard"
git push origin main
<span class="c"># Then add a CNAME DNS record pointing to YOUR-ORG.github.io</span></pre>
      </div>
    </div>

    <div class="callout callout-tip">
      <span class="callout-icon">✅</span>
      <div class="callout-body">
        <strong>You're done.</strong>
        GitHub Actions now runs tfsec + Checkov on every PR, Terraform applies on merge to main, and a daily job at 06:00 UTC checks live compliance state across AWS Config, GuardDuty, and Security Hub — alerting Slack on any failures.
      </div>
    </div>
  </div>

</main>
</div>

<script>
// ── Copy buttons ─────────────────────────────────
function copyCode(btn) {
  const pre = btn.closest('.code-block').querySelector('pre');
  const text = pre.innerText;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 2000);
  });
}

// ── Sidebar active state on scroll ────────────────
const steps = document.querySelectorAll('.step[id]');
const navLinks = document.querySelectorAll('#sidebar-nav a');
const progress = document.getElementById('progress');

const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(a => a.classList.remove('active'));
      const active = document.querySelector(`#sidebar-nav a[href="#${e.target.id}"]`);
      if (active) active.classList.add('active');
    }
  });
}, { rootMargin: '-15% 0px -70% 0px' });

steps.forEach(s => obs.observe(s));

// ── Reading progress bar ───────────────────────────
window.addEventListener('scroll', () => {
  const total = document.body.scrollHeight - window.innerHeight;
  const pct = total > 0 ? (window.scrollY / total) * 100 : 0;
  progress.style.width = pct + '%';
});
</script>
</body>
