        <pre><span class="c"># Unzip the downloaded project</span>
unzip terraform-pci-compliance.zip
cd terraform-pci-compliance

<span class="c"># Create .gitignore — prevents secrets from being committed</span>
cat > .gitignore &lt;&lt; 'EOF'
*.tfvars
*.tfvars.json
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
tfplan
*.pem
